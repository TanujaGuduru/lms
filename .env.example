# ═══════════════════════════════════════════════════════
#  CodeGurukul LMS — Environment Configuration Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────────
APP_NAME="CodeGurukul LMS"
APP_URL=http://localhost
APP_ENV=production          # local | production
APP_DEBUG=false             # true only in local
APP_KEY=base64:REPLACE_WITH_32_CHAR_RANDOM_STRING
APP_TIMEZONE=Asia/Kolkata

# ── Database ─────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=codegurukul
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# ── Session ──────────────────────────────────────────────
SESSION_DRIVER=file         # file | database
SESSION_LIFETIME=120        # minutes
SESSION_SECURE=true         # true in production (requires HTTPS)

# ── Mail / SMTP ───────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@codegurukul.in
MAIL_FROM_NAME="CodeGurukul LMS"

# ── Payment Gateways ─────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXX
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXX

# ── Storage ───────────────────────────────────────────────
UPLOAD_MAX_SIZE=10          # MB
UPLOAD_PATH=/uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp,pdf,doc,docx,xls,xlsx,ppt,pptx,mp4,mp3,zip

# ── SMS / OTP ────────────────────────────────────────────
SMS_PROVIDER=twilio         # twilio | msg91
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM=+1XXXXXXXXXX

MSG91_API_KEY=your_msg91_api_key
MSG91_SENDER_ID=CGURU

# ── AI Integration ────────────────────────────────────────
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXX
OPENAI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=2048

# ── Redis (optional — for queue/cache) ───────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=error             # debug | info | warning | error
LOG_CHANNEL=file

# ── Security ──────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=30
PASSWORD_MIN_LENGTH=8
SESSION_TIMEOUT_MINUTES=120
TWO_FACTOR_REQUIRED=false

# ── Backup ────────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily      # daily | weekly | monthly
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/storage/backups

# ── AWS S3 (optional backup storage) ─────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=codegurukul-backups
