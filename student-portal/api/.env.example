APP_NAME="CodeGurukul Student Portal API"
APP_URL=https://yourdomain.com/api
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Kolkata

# Signs local-file download URLs (App\Core\FileStorage) and must be set —
# the app refuses to boot without it (bootstrap/app.php). Any long random
# string; generate one any way you like, e.g. a password manager's generator.
# Not the same value as the Admin panel's own APP_KEY.
APP_KEY=

# Same domain, different path as the frontend (web/) per the chosen GoDaddy
# layout — see ../README.md.
FRONTEND_URL=https://yourdomain.com

DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=codegurukul
DB_USERNAME=
DB_PASSWORD=

# Live classroom is pure peer-to-peer WebRTC (app/Controllers/Api/ClassroomController.php)
# — no video service, no account, no key needed. The only "external" piece is
# Google's free public STUN server, hardcoded in the controller since it
# needs no configuration at all.

# Materials/recordings are stored on local disk (storage/app/...), not S3 —
# see app/Core/FileStorage.php. Nothing to configure here; this is a no-op
# section kept only so the convention is documented where you'd look for it.

# AI Doubt Solver / Coding Assistant (app/Core/AiGateway.php) — the one
# accepted external dependency: a direct, pay-per-call API to Anthropic.
# No AI features work at all until this key is set; everything else in this
# app runs with zero external dependency regardless.
AI_API_KEY=
AI_BASE_URL=https://api.anthropic.com
AI_FAST_MODEL=claude-haiku-4-5-20251001
AI_DEEP_MODEL=claude-sonnet-4-6
AI_DAILY_MESSAGE_LIMIT=15

# Once a student's computed age (users.date_of_birth) reaches this, parent
# endpoints stop serving that student on stale minor-era consent
# (app/Controllers/Api/ParentController.php) — docs/student-module/04f's
# "policy moment" requirement.
ADULT_AGE_THRESHOLD=18

# Course Completion (04g) — neither has a dedicated settings table; both are
# plain config. See cron/check-course-completion.php and App\Core\CourseCompletion.
GRACE_PERIOD_DAYS=14
ATTENDANCE_REQUIRED_PERCENT=75

# Communication Engine (docs/student-module/06, App\Core\Notifier) — email
# channel only, sent via App\Core\SimpleMailer's hand-rolled SMTP client
# straight to your GoDaddy cPanel mailbox (already part of the hosting plan,
# not a third-party cloud add-on). Same variable names as the Admin panel's
# own .env.example, so both apps can point at the same mailbox. WhatsApp/SMS
# channels are not implemented in this build — see App\Core\Notifier's
# docblock for why — so there is nothing to configure for those.
MAIL_HOST=
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@codegurukul.in
MAIL_FROM_NAME="CodeGurukul"
